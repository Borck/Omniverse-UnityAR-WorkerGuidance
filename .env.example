# Server endpoints
GUIDANCE_HTTP_BASE_URL=http://localhost:8080
GUIDANCE_GRPC_ENDPOINT=localhost:50051

# Stage source
GUIDANCE_STAGE_URI=

# Local asset/cache roots
GUIDANCE_ASSET_ROOT=./shared/samples/assets
GUIDANCE_TARGET_ROOT=./shared/samples/targets
GUIDANCE_EXPORT_ASSET_ROOT=./shared/samples/assets
GUIDANCE_EXPORT_MANIFEST_ROOT=./shared/samples/manifests
GUIDANCE_EXPORT_JOB_STORE_FILE=./server-kit/runtime/export-jobs.json

# Optional Draco compression for streamed GLB transfer.
# Command template must support placeholders {input} and {output}.
GUIDANCE_DRACO_ENABLED=false
GUIDANCE_DRACO_TOOLCHAIN=gltf-transform
GUIDANCE_DRACO_ENCODER_CMD=
